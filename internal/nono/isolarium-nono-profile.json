{

   "meta": {
        "name": "isolarium",
        "version": "0.0.1",
        "description": "Initially Claude Code",
        "author": "isolarium"
      },
      "security": {
        "groups": ["user_caches_macos", "node_runtime", "rust_runtime", "python_runtime", "vscode", "unlink_protection"]
      },
      "trust_groups": [],
      "filesystem": {
        "allow": ["$HOME/.claude", "$HOME/.hitl", "$HOME/.gradle"],
        "read": ["$HOME/.local/share/claude", "$HOME/.config/gh", "$HOME/.cache/uv", "$HOME/.local/share/uv", "$HOME/.sdkman"],
        "allow_file": ["$HOME/.claude.json", "$HOME/.claude.json.lock"],
        "read_file": ["$HOME/Library/Keychains/login.keychain-db", "$HOME/.gitconfig", "$HOME/.gitignore_global", "$HOME/.config/git/ignore"]
      },
      "workdir": { "access": "readwrite" },
      "hooks": {
        "claude-code": {
          "event": "PostToolUseFailure",
          "matcher": "Read|Write|Edit|Bash",
          "script": "nono-hook.sh"
        }
      },
      "undo": {
        "exclude_patterns": ["node_modules", ".next", "__pycache__", "target"],
        "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
      },
      "interactive": true
    }